<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil - Álbumes de Fotos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">📸 Mi Perfil</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#perfil">Perfil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#albumes">Álbumes</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contactos">Contactos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#favoritos">Favoritos</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <!-- SECCIÓN DE PERFIL -->
        <section id="perfil" class="mb-5">
            <div class="row">
                <div class="col-md-4">
                    <div class="card shadow">
                        <img src="<%= perfil.foto %>" class="card-img-top" alt="<%= perfil.nombre %>">
                        <div class="card-body text-center">
                            <h4 class="card-title"><%= perfil.nombre %></h4>
                            <p class="card-text text-muted"><%= perfil.descripcion %></p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN DE ÁLBUMES -->
        <section id="albumes" class="mb-5">
            <h2 class="mb-4">Mis Álbumes</h2>
            <div class="row" id="albumesContainer">
                <% albumes.forEach(album => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card album-card cursor-pointer" onclick="cargarFotosAlbum(<%= album.id %>)">
                            <img src="<%= album.foto %>" class="card-img-top" alt="<%= album.nombre %>">
                            <div class="card-body text-center">
                                <h5 class="card-title"><%= album.nombre %></h5>
                                <p class="card-text text-muted"><%= album.fotos.length %> fotos</p>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>

            <!-- Galería de fotos del álbum seleccionado -->
            <div id="galeriaAlbum" class="mt-5" style="display: none;">
                <button class="btn btn-secondary mb-3" onclick="cerrarGaleria()">← Volver a Álbumes</button>
                <h3 id="tituloAlbum"></h3>
                <div class="row" id="fotosContainer"></div>
            </div>
        </section>

        <!-- SECCIÓN DE CONTACTOS -->
        <section id="contactos" class="mb-5">
            <h2 class="mb-4">Mis Contactos</h2>
            <button class="btn btn-primary mb-3" id="btnCargarContactos" onclick="cargarContactos()">
                Cargar Contactos
            </button>
            <div id="contactosContainer" class="row"></div>
        </section>

        <!-- SECCIÓN DE FAVORITOS -->
        <section id="favoritos" class="mb-5">
            <h2 class="mb-4">Fotos Favoritas</h2>
            <button class="btn btn-info mb-3" onclick="cargarFavoritos()">Mostrar Favoritos</button>
            <div id="favoritosContainer" class="row"></div>
        </section>
    </div>

    <!-- Modal para ver foto completa -->
    <div class="modal fade" id="modalFoto" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitulo"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <img id="modalImagen" src="" class="img-fluid" alt="">
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger" id="btnLike" onclick="darLike()">
                        👍 <span id="likeCount">0</span>
                    </button>
                    <button class="btn btn-outline-warning" id="btnFavorito" onclick="agregarFavorito()">
                        ⭐ Agregar a Favoritos
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
